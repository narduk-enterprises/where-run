# EditorConfig – https://editorconfig.org
# Mirrors prettier.config.mjs so editors and CI are always in sync.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.{md,mdx}]
# Prettier prose-wraps Markdown for us; don't trim meaningful trailing spaces
trim_trailing_whitespace = false
max_line_length = 80

[*.{yaml,yml}]
indent_size = 2

[*.{json,jsonc,json5}]
indent_size = 2

[Makefile]
indent_style = tab
