{
  "name": "eslint-plugin-nuxt-guardrails",
  "version": "1.0.0",
  "description": "ESLint plugin to enforce Nuxt 4 best practices and flag legacy Nuxt 2/3 patterns",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "gen:spec": "tsx scripts/gen-nuxt-spec.ts",
    "build": "tsup",
    "prepare": "tsup"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "nuxt",
    "nuxt4",
    "vue",
    "linting"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0",
    "vue-eslint-parser": "^10.2.0"
  },
  "dependencies": {
    "@types/node": "^20.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.56.1",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
