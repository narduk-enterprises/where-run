{
  "name": "@narduk-enterprises/narduk-nuxt-template-layer",
  "version": "1.0.11",
  "type": "module",
  "description": "Narduk Nuxt 4 Layer — shared components, composables, server routes, and Drizzle schema for Cloudflare Workers apps",
  "repository": {
    "type": "git",
    "url": "git@github.com:narduk-enterprises/where-run.git",
    "directory": "layers/narduk-nuxt-layer"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "nuxt prepare",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint . --max-warnings 0",
    "test:unit": "vitest run",
    "quality": "pnpm run test:unit",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "format:check": "prettier --check \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\" --ignore-path ../../.gitignore"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "4.5.0",
    "@nuxtjs/seo": "^3.4.0",
    "@takumi-rs/core": "^0.70.1",
    "@takumi-rs/wasm": "^0.70.1",
    "drizzle-orm": "^0.45.1",
    "nuxt-auth-utils": "^0.5.29",
    "jose": "^6.1.3",
    "postcss": "^8.5.6",
    "posthog-js": "^1.205.0",
    "satori": ">=0.19.2",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@iconify-json/lucide": "^1.2.94",
    "@narduk-enterprises/eslint-config": "^1.0.12",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.19.13",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "happy-dom": "^20.7.0",
    "nuxt": "^4.3.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
  },
  "peerDependencies": {
    "nuxt": ">=3.16.0",
    "wrangler": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "wrangler": {
      "optional": true
    }
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "@nuxt/fonts": "0.14.0",
    "nuxt-og-image": "6.0.0-beta.47",
    "@takumi-rs/core": ">=0.70.1",
    "@takumi-rs/wasm": ">=0.70.1",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "exports": {
    ".": {
      "import": "./nuxt.config.ts"
    },
    "./server/*": "./server/*",
    "./app/*": "./app/*",
    "./components/*": "./components/*",
    "./testing/*": "./testing/*",
    "./server/database/schema": {
      "import": "./server/database/schema.ts"
    },
    "./drizzle/*": "./drizzle/*"
  },
  "files": [
    "app/",
    "components/",
    "public/",
    "server/",
    "testing/",
    "drizzle/",
    "nuxt.config.ts",
    "tsconfig.json",
    "drizzle.config.ts"
  ],
  "volta": {
    "node": "22.22.0"
  }
}
